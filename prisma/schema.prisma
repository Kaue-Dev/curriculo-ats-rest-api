generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  analyses     Analysis[]
  creditGrants CreditGrant[]
  creditUsages CreditUsage[]
  payments     Payment[]
}

model Analysis {
  id        String   @id @default(uuid())
  sessionId String
  createdAt DateTime @default(now())

  filename String?
  model    String?

  resumeText String? @db.Text

  evaluation Json

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt(sort: Desc)])
}

model CreditGrant {
  id        String   @id @default(uuid())
  sessionId String
  createdAt DateTime @default(now())

  credits Int
  reason  String?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt(sort: Desc)])
}

model CreditUsage {
  id        String   @id @default(uuid())
  sessionId String
  analysisId String?
  createdAt DateTime @default(now())

  credits Int
  reason  String?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt(sort: Desc)])
}

model Payment {
  id        String   @id @default(uuid())
  provider  String
  createdAt DateTime @default(now())

  sessionId String
  amount    Decimal @db.Decimal(10, 2)
  currency  String

  preferenceId String?
  paymentId    String? @unique
  status       String
  raw          Json?

  processedAt DateTime?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([provider, createdAt(sort: Desc)])
  @@index([sessionId, createdAt(sort: Desc)])
}
